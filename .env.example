# Copy sang .env.local cho dev, hoặc set trên Railway/Vercel cho production

# URL của socket server — để trống nếu frontend + socket cùng server
NEXT_PUBLIC_SOCKET_URL=

# Supabase (tùy chọn — MVP chạy in-memory, không cần DB)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# CORS origin cho production (Vercel URL)
CORS_ORIGIN=*
